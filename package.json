{
  "name": "bindu-js",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo root for bindu JS SDK",
  "packageManager": "pnpm@8.15.6",
  "workspaces": [
    "package"
  ],
  "scripts": {
    "build": "pnpm --filter @bindu-js/sdk build",
    "dev": "pnpm --filter @bindu-js/sdk dev",
    "test": "pnpm --filter @bindu-js/sdk test",
    "lint": "pnpm --filter @bindu-js/sdk lint",
    "typecheck": "pnpm --filter @bindu-js/sdk typecheck"
  }
}
